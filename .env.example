# PatchPilot local self-hosted configuration.
# Copy this file to .env and replace placeholder values.

# Spring runtime
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=docker

# Frontend dev server proxy target.
# Use http://127.0.0.1:18080 when the backend is started from the IDEA run configuration.
PATCHPILOT_FRONTEND_BACKEND_URL=http://127.0.0.1:8080

# Optional public dashboard URL used in GitHub issue comments and Pull Request bodies.
# Set this to the URL maintainers can open, for example a Cloudflare Tunnel frontend URL.
PATCHPILOT_DASHBOARD_BASE_URL=

# GitHub webhook verification.
# Must match the secret configured in GitHub repository Settings -> Webhooks.
PATCHPILOT_GITHUB_WEBHOOK_SECRET=replace-with-random-secret

# Optional operator API token for dashboard and curl access.
# Set this before exposing the backend through a public temporary tunnel.
PATCHPILOT_ADMIN_TOKEN=replace-with-random-admin-token
# Local-only dashboard convenience. Keep false when using a public or shared URL.
PATCHPILOT_DASHBOARD_ADMIN_TOKEN_BOOTSTRAP_ENABLED=false

# GitHub API token for clone, push, issue comments, and Pull Request creation.
# Use a fine-grained token scoped to the test repository when possible.
PATCHPILOT_GITHUB_TOKEN=replace-with-github-token

# Optional safety allowlists. Leave empty for unrestricted local development.
# Comma-separated GitHub logins and owner/repository names.
PATCHPILOT_ALLOWED_TRIGGER_USERS=
PATCHPILOT_ALLOWED_REPOSITORIES=

# Optional model-assisted trigger classification.
# When true, PatchPilot asks the configured model whether a safe /agent fix request is concrete enough to execute.
PATCHPILOT_MODEL_TRIGGER_CLASSIFICATION_ENABLED=false

# Trigger abuse guard. Rejects excessive /agent fix attempts before model calls or task creation.
PATCHPILOT_TRIGGER_RATE_LIMIT_ENABLED=true
PATCHPILOT_TRIGGER_RATE_LIMIT_WINDOW_MS=600000
PATCHPILOT_TRIGGER_RATE_LIMIT_MAX_PER_TRIGGER_USER=30
PATCHPILOT_TRIGGER_RATE_LIMIT_MAX_PER_REPOSITORY=60
PATCHPILOT_TRIGGER_RATE_LIMIT_MAX_PER_ISSUE=20

# Workspace root inside the backend container.
PATCHPILOT_WORKSPACE_ROOT_DIR=/tmp/patchpilot/workspaces

# Local paths that /api/repository-preflight may inspect.
# Comma-separated paths. Relative paths resolve from the backend working directory.
PATCHPILOT_REPOSITORY_PREFLIGHT_ALLOWED_ROOT_DIRS=.,docs/demo-repositories

# OpenAI-compatible model provider.
PATCHPILOT_AGENT_PROVIDER=openai-compatible
PATCHPILOT_AGENT_MODEL=gpt-4.1-mini
PATCHPILOT_AGENT_BASE_URL=https://api.openai.com/v1
PATCHPILOT_AGENT_API_KEY=replace-with-model-provider-api-key
PATCHPILOT_AGENT_COST_PROMPT_TOKEN_USD=0
PATCHPILOT_AGENT_COST_COMPLETION_TOKEN_USD=0
